#!/bin/bash

# note: create/open markdown notes under ~/Documents/notes
#
# Create notes with optional topic (subdirectory) and name.
# Notes are automatically dated with format: Day_DD-MM-YY
#
# Examples:
#   note                          # Create diary note
#   note work                      # Create note in work/ topic
#   note "my project" "meeting"    # Create named note in topic

NOTES_DIR="${HOME}/Documents/notes"
DIARY_DIR="${NOTES_DIR}/diary"

print_help() {
  cat <<'EOF'
Usage: note [topic] [note_name]

Create and open markdown notes in ~/Documents/notes

Arguments:
  topic          Optional topic/subdirectory for the note
  note_name      Optional name for the note (default: date only)

Options:
  -h, --help     Show this help message and exit

Examples:
  note
  note work
  note "my project"
  note "my project" "meeting notes"
EOF
}

resolve_target_file() {
  local first_arg="$1"
  local second_arg="$2"

  if [[ -n "$first_arg" && -f "${NOTES_DIR}/${first_arg}" ]]; then
    printf '%s\n' "${NOTES_DIR}/${first_arg}"
    return 0
  fi

  local label="${first_arg// /_}"
  local note_name="${second_arg// /_}"
  local date_str
  date_str="$(date "+%a_%d-%m-%y")"

  if [[ -n "$label" ]]; then
    mkdir -p "${NOTES_DIR}/${label}"
    if [[ -n "$note_name" ]]; then
      printf '%s\n' "${NOTES_DIR}/${label}/${note_name}-${date_str}.md"
    else
      printf '%s\n' "${NOTES_DIR}/${label}/${date_str}.md"
    fi
  else
    mkdir -p "$DIARY_DIR"
    printf '%s\n' "${DIARY_DIR}/${date_str}.md"
  fi
}

open_note_file() {
  local target_file="$1"
  nvim "$target_file"
}

main() {
  local arg1="${1-}"
  local arg2="${2-}"

  case "$arg1" in
  -h | --help)
    print_help
    return 0
    ;;
  esac

  local target_file
  target_file="$(resolve_target_file "$arg1" "$arg2")"
  open_note_file "$target_file"
}

main "$@"
