[Desktop Entry]
Name=1Password
Exec=env -u WAYLAND_DISPLAY -u ELECTRON_OZONE_PLATFORM_HINT -u OZONE_PLATFORM -u MOZ_ENABLE_WAYLAND /opt/1Password/1password --ozone-platform=x11 %U
Terminal=false
Type=Application
Icon=1password
StartupWMClass=1Password
Comment=Password manager and secure wallet
MimeType=x-scheme-handler/onepassword;x-scheme-handler/onepassword8;
Categories=Office;
