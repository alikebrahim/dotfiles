[global]
    monitor = 0
    follow = mouse
    width = 300
    height = (0, 300)
    origin = top-right
    offset = (10, 40)
    scale = 0
    notification_limit = 0
    
    ### Progress Bar ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4
    progress_bar_corners = all
    icon_corner_radius = 6
    icon_corners = all
    
    indicate_hidden = yes
    transparency = 8
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    text_icon_padding = 0
    frame_width = 2
    frame_color = "#7e9cd8"
    corner_radius = 8
    corners = all
    gap_size = 6
    separator_color = frame
    sort = yes
    
    ### Text ###
    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 0
    max_icon_size = 32
    
    ### History ###
    sticky_history = yes
    history_length = 20
    
    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1f1f28"
    foreground = "#dcd7ba"
    timeout = 5

[urgency_normal]
    background = "#1f1f28"
    foreground = "#dcd7ba"
    timeout = 10

[urgency_critical]
    background = "#1f1f28"
    foreground = "#c34043"
    frame_color = "#c34043"
    timeout = 20
