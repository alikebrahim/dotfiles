#!/bin/bash

# Configuration
THEME_LIB="$HOME/.dotfiles/themes/library"
ACTIVE_THEME_FILE="$HOME/.dotfiles/themes/active_theme.name"
COLORS_LUA="$HOME/.dotfiles/awesome/.config/awesome/theme/colors.lua"
POLYBAR_COLORS="$HOME/.dotfiles/polybar/.config/polybar/colors.ini"
ROFI_COLORS="$HOME/.dotfiles/rofi/.config/rofi/colors.rasi"
DUNST_CONFIG="$HOME/.dotfiles/dunst/.config/dunst/dunstrc"

THEME_NAME=$1

if [[ -z "$THEME_NAME" ]]; then
    echo "Usage: theme-apply <theme_name>"
    exit 1
fi

THEME_PATH="$THEME_LIB/$THEME_NAME"

if [[ ! -d "$THEME_PATH" ]]; then
    # Fallback to lowercase hyphenated if needed (omarchy style)
    THEME_NAME=$(echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
    THEME_PATH="$THEME_LIB/$THEME_NAME"
fi

if [[ ! -d "$THEME_PATH" ]]; then
    echo "Error: Theme $1 not found in library."
    exit 1
fi

COLORS_TOML="$THEME_PATH/colors.toml"

if [[ ! -f "$COLORS_TOML" ]]; then
    echo "Error: colors.toml missing in $THEME_NAME"
    exit 1
fi

# Helper to extract colors from TOML
get_color() {
    grep "^$1 =" "$COLORS_TOML" | cut -d'"' -f2
}

BG=$(get_color "background")
FG=$(get_color "foreground")
ACCENT=$(get_color "accent")
CR=$(get_color "cursor")
C0=$(get_color "color0")
C1=$(get_color "color1")
C2=$(get_color "color2")
C3=$(get_color "color3")
C4=$(get_color "color4")
C5=$(get_color "color5")
C6=$(get_color "color6")
C7=$(get_color "color7")
C8=$(get_color "color8")

# 1. Update AwesomeWM Colors
cat <<EOF > "$COLORS_LUA"
-- Generated by theme-apply
local colors = {
    bg = "$BG",
    fg = "$FG",
    accent = "$ACCENT",
    cursor = "$CR",
    color0 = "$C0",
    color1 = "$C1",
    color2 = "$C2",
    color3 = "$C3",
    color4 = "$C4",
    color5 = "$C5",
    color6 = "$C6",
    color7 = "$C7",
    color8 = "$C8",
}
return colors
EOF

# 2. Update Polybar colors.ini
cat <<EOF > "$POLYBAR_COLORS"
; Generated by theme-apply
[colors]
background = $BG
foreground = $FG
primary = $ACCENT
secondary = $C4
alert = $C1
disabled = $C8
EOF

# 3. Update Rofi colors.rasi
cat <<EOF > "$ROFI_COLORS"
/* Generated by theme-apply */
* {
    bg: $BG;
    fg: $FG;
    accent: $ACCENT;
    urgent: $C1;
}
EOF

# 4. Update Dunst dunstrc
sed -i "s/frame_color = \".*\"/frame_color = \"$ACCENT\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_low\]/,/background/s/background = \".*\"/background = \"$BG\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_low\]/,/foreground/s/foreground = \".*\"/foreground = \"$FG\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_normal\]/,/background/s/background = \".*\"/background = \"$BG\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_normal\]/,/foreground/s/foreground = \".*\"/foreground = \"$FG\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_critical\]/,/background/s/background = \".*\"/background = \"$BG\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_critical\]/,/foreground/s/foreground = \".*\"/foreground = \"$C1\"/" "$DUNST_CONFIG"
sed -i "/\[urgency_critical\]/,/frame_color/s/frame_color = \".*\"/frame_color = \"$C1\"/" "$DUNST_CONFIG"

# Save state
echo "$THEME_NAME" > "$ACTIVE_THEME_FILE"

# [FUTURE EXPERIMENTATION - COMMENTED OUT]
# # Update Alacritty
# # Update Wezterm
# # Update Neovim (via session file or symlink)

# Reload AwesomeWM (if running)
if pgrep -x awesome > /dev/null; then
    awesome-client 'awesome.restart()'
fi

# Reload Polybar (if running)
if pgrep -x polybar > /dev/null; then
    pkill -USR1 polybar || (pkill polybar && sleep 1 && polybar main &)
fi

# Reload Dunst (if running)
if pgrep -x dunst > /dev/null; then
    dunstctl reload
fi
